# Python
__pycache__/
*.py[cod]
*$py.class
venv/
venv*/
.venv/
*.egg-info/

# Node
node_modules/
dist/
.vite/

# Environment
.env
.env.local

# Homelab deployment — private infra (Cloudflare tunnel, OPNsense, Traefik,
# internal IPs). Not needed to run locally; kept out of the public repo.
deploy/
DEPLOY.md

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# PowerPoint / Word lockfiles (auto-created while a doc is open)
~$*

# Course deliverables / reports — kept local, submitted via Moodle, not
# shipped to GitHub so the public repo stays a clean clone-and-run project.
docs/

# Datasets (too large to commit) — exclude everything under data/ by default…
data/*
datasets/
*.mp4
*.avi
!backend/tests/fixtures/*.mp4

# …but keep small eval result CSVs (these are deliverable artifacts)
!data/compare_pos_chrom_*.csv
!data/eval_*.csv

# …and keep the scan history starter so docker compose can bind-mount it
# as a file (not auto-create as a directory) on a fresh clone.
!data/scan_history.json

# Models
*.pt
*.pth
*.h5

# Logs
*.log

# local firewall API creds (do not commit)
.firewall.env
